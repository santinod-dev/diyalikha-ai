# ── IBM Cloud / watsonx.ai ─────────────────────────────────────────────────────
IBM_API_KEY=your_ibm_cloud_api_key_here
WATSONX_URL=https://au-syd.ml.cloud.ibm.com
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# Optional: override the default LLM model
# WATSONX_MODEL_ID=meta-llama/llama-3-3-70b-instruct

# ── IBM Cloud Object Storage ───────────────────────────────────────────────────
COS_API_KEY=your_cos_api_key_here
COS_INSTANCE_CRN=your_cos_instance_crn_here
COS_ENDPOINT=https://s3.au-syd.cloud-object-storage.appdomain.cloud
COS_BUCKET=diyalikha-uploads

# ── Firebase Admin (Auth + Firestore only — no Storage) ───────────────────────
# Option A: path to the service account JSON file (local dev)
FIREBASE_SERVICE_ACCOUNT_PATH=backend/serviceAccountKey.json
# Option B: base64-encoded service account JSON (container/cloud deployments)
# FIREBASE_SERVICE_ACCOUNT=<base64 encoded JSON>

# ── CORS ───────────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173
